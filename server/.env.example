# MongoDB Atlas Connection String
# Replace with your MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/imagify?retryWrites=true&w=majority

# JWT Secret for authentication
# Generate a secure random string (e.g., using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here

# Frontend URL for CORS configuration
# Replace with your Vercel frontend URL after deployment
FRONTEND_URL=https://your-frontend.vercel.app

# Razorpay Payment Gateway (optional - only if using payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Server Port (default: 4000)
PORT=4000
