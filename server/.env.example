# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/imagify?retryWrites=true&w=majority

# JWT Secret for authentication (generate a random string)
JWT_SECRET=your_super_secret_random_string_here

# ClipDrop API Key for image generation
CLIPDROP_API=your_clipdrop_api_key_here

# Razorpay Payment Gateway (optional - for credit purchases)
RAZORPAY_ID=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_key_secret
